OPENABM_ENV=local
OPENABM_DATABASE_URL=sqlite:///.openabm/openabm.sqlite3
OPENABM_PAYLOAD_DIR=.openabm/payloads
OPENABM_MODEL_MODE=local
OPENABM_MODEL_BASE_URL=http://127.0.0.1:1234/v1
OPENABM_CHAT_MODEL=qwen3.5-9b-mlx
OPENABM_EMBEDDING_MODEL=
OPENABM_ALLOW_EXTERNAL_MODEL_CALLS=false
OPENABM_JUDGE_CONCURRENCY=1
OPENABM_EMBEDDING_CONCURRENCY=0
OPENABM_MODEL_CONTEXT_LENGTH=262144
OPENABM_MAX_TRACE_TOKENS_FOR_JUDGE=262144
OPENABM_MODEL_MIN_AVAILABLE_MEMORY_MB=8192
OPENABM_INGEST_MAX_BATCH_ITEMS=5000
OPENABM_INGEST_RETRYABLE_BACKPRESSURE_ITEMS=10000
OPENABM_INGEST_INLINE_PAYLOAD_MAX_BYTES=262144
OPENABM_INGEST_MAX_EVENTS_PER_SPAN=500
OPENABM_INGEST_STREAM_EVENT_SAMPLE_RATE=10
OPENABM_ENABLE_EXTERNAL_NOTIFICATIONS=false
