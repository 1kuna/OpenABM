# Copy this file outside git or export equivalent environment variables before
# running `docker compose --env-file .env.production -f deploy/compose.yaml up --build`.
OPENABM_ENV=production-reference
OPENABM_API_PORT=8787
OPENABM_WEB_PORT=8080

# Replace both values before exposing a deployment beyond localhost.
OPENABM_DEV_API_KEY=replace-with-a-long-random-api-key
OPENABM_SECRET_KEY=replace-with-a-long-random-secret-key

# Local-first model defaults. For Docker Desktop on macOS, host.docker.internal
# reaches an LM Studio server running on the host.
OPENABM_MODEL_MODE=disabled
OPENABM_MODEL_BASE_URL=http://host.docker.internal:1234/v1
OPENABM_CHAT_MODEL=qwen3.5-9b-mlx
OPENABM_EMBEDDING_MODEL=
OPENABM_ALLOW_EXTERNAL_MODEL_CALLS=false
OPENABM_MODEL_CONTEXT_LENGTH=262144
OPENABM_MAX_TRACE_TOKENS_FOR_JUDGE=262144

OPENABM_ENABLE_EXTERNAL_NOTIFICATIONS=false
OPENABM_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
