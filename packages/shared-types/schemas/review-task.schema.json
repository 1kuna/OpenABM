{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openabm.dev/schemas/review-task.json",
  "title": "ReviewTask",
  "type": "object",
  "additionalProperties": false,
  "required": ["review_task_id", "project_id", "task_type", "source_entity_type", "source_entity_id", "status", "created_at", "updated_at"],
  "properties": {
    "review_task_id": {"type": "string"},
    "project_id": {"type": "string"},
    "task_type": {"enum": ["judge_output", "behavior_candidate", "grounding_check", "affected_entity", "root_cause_candidate"]},
    "source_entity_type": {"type": "string"},
    "source_entity_id": {"type": "string"},
    "assigned_to_nullable": {"type": ["string", "null"]},
    "status": {"enum": ["open", "accepted", "rejected", "needs_more_evidence", "resolved"]},
    "decision_nullable": {"type": ["string", "null"]},
    "notes_nullable": {"type": ["string", "null"]},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "default": []},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
