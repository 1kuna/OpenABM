{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openabm.dev/schemas/now-event-advance.schema.json",
  "title": "NowEventAdvanceRequest",
  "type": "object",
  "required": ["project_id", "action"],
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": ["approve", "verify", "close", "ignore"]
    }
  }
}
