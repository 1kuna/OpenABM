{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openabm.dev/schemas/agent-config.json",
  "title": "AgentConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_config_id", "project_id", "name", "config_type", "created_at"],
  "properties": {
    "agent_config_id": {"type": "string"},
    "project_id": {"type": "string"},
    "name": {"type": "string"},
    "config_type": {"enum": ["tool", "retrieval", "guardrail", "memory", "routing", "workflow", "feature_flags", "runtime", "instruction_bundle"]},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
