{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openabm.dev/schemas/secret-reference.json",
  "title": "SecretReference",
  "type": "object",
  "additionalProperties": false,
  "required": ["secret_ref", "project_id", "purpose", "status", "current_version", "encryption_mode", "created_at", "updated_at"],
  "properties": {
    "secret_ref": {"type": "string"},
    "org_id": {"type": "string"},
    "project_id": {"type": "string"},
    "purpose": {"type": "string"},
    "provider": {"type": ["string", "null"]},
    "status": {"enum": ["active", "rotated", "revoked", "deleted"]},
    "current_version": {"type": "integer", "minimum": 1},
    "encryption_mode": {"type": "string"},
    "ciphertext_sha256": {"type": "string"},
    "has_value": {"type": "boolean"},
    "redacted_value": {"type": "string"},
    "rotation_due_at": {"type": ["string", "null"], "format": "date-time"},
    "rotated_at": {"type": ["string", "null"], "format": "date-time"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "deleted_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
