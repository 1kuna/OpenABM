{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openabm.dev/schemas/grounding-check.json",
  "title": "GroundingCheck",
  "type": "object",
  "additionalProperties": false,
  "required": ["grounding_check_id", "project_id", "trace_id", "status", "claims", "evidence_span_ids", "created_at"],
  "properties": {
    "grounding_check_id": {"type": "string"},
    "project_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "span_id_nullable": {"type": ["string", "null"]},
    "status": {"enum": ["supported", "needs_review", "unsupported", "contradicted", "insufficient_evidence", "not_checked"]},
    "claims": {"type": "array", "items": {"type": "object"}},
    "evidence_span_ids": {"type": "array", "items": {"type": "string"}},
    "contradicted_span_ids": {"type": "array", "items": {"type": "string"}},
    "model_extraction": {"type": "object"},
    "model_contradiction_adjudication": {"type": "object"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
